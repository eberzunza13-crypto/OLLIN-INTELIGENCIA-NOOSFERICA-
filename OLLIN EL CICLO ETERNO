class OLLINShell:
    def __init__(self):
        self.inference = InferenceEngine({"backend": "ollama", "model": "phi3"})
        self.embed = EmbeddingEngine()
        self.vectors = VectorDB(self.embed)
        self.vision = VisionEngine()
        self.triaje = TriajeEngine()
        self.mecp = MECP()
        self.camara = CamaraDialogo(self.inference)
        self.ollin = AgenteOllin(self)
        self.ometeotl = AgenteOmeteotl(self)
        self.coatlicue = AgenteCoatlicue(self)
        self.enjambre = AgenteEnjambre(self)
        self.cola_ingesta = queue.Queue()
        self.exploradores_activos = False
        self.hilos_exploradores = []

    # ----------------------------------------------------------------------
    # Ingesta con Capa Anti‑Bias, geolocalización y registro en Ometeotl
    # ----------------------------------------------------------------------
    def ingestar_nodo(self, texto, fuente, etiqueta, categoria="", analizar=True,
                      lat=None, lon=None, fuente_geo=""):
        if not texto.strip():
            return None
        datos = aplicar_antibias(texto, fuente, etiqueta)
        triaje_info = self.triaje.etiquetar(datos["texto_original"])
        # Detectar coordenadas en texto (simplificado)
        if lat is None and lon is None:
            # Ejemplo: extraer de mención geográfica (placeholder)
            pass
        nodo_existente = buscar_nodo_similar(datos["texto_original"])
        if nodo_existente:
            guardar_adiccion(nodo_existente, datos["texto_original"], fuente, categoria, datos["estado_epistemico"])
            print(colorize(f"  Acumulado en nodo {nodo_existente}", "green"))
            nodo_id = nodo_existente
        else:
            nodo_id = crear_nodo(datos["texto_original"], fuente, etiqueta, categoria,
                                 datos["estado_epistemico"], lat, lon, fuente_geo)
            if analizar:
                # Ollin desdobla en Sueño/Mitote
                self.ollin.desdoblar(nodo_id, datos["texto_original"], categoria)
            print(colorize(f"  Nuevo nodo {nodo_id} guardado", "green"))
        registrar_evento("nodo_creado", f"Nodo {nodo_id} desde {fuente}", nodo_id)
        self.mecp.registrar("usuario", texto, fuente)
        if self.embed.available:
            vec = self.embed.encode(datos["texto_original"])
            self.vectors.add([nodo_id], [vec], [{"texto": datos["texto_original"][:500], "fuente": fuente}])
        return nodo_id

    def encolar_nodo(self, texto, fuente, etiqueta, categoria=""):
        # Evitar duplicados (hash simple)
        hash_candidato = generar_hash(texto[:100])
        conn = sqlite3.connect(AHO_DB)
        c = conn.cursor()
        c.execute("SELECT id FROM nodos WHERE hash = ?", (hash_candidato,))
        if c.fetchone():
            conn.close()
            return
        conn.close()
        self.cola_ingesta.put((texto, fuente, etiqueta, categoria))

    def iniciar_exploradores(self, num_hilos=2):
        if self.exploradores_activos:
            return
        # Usar modelos ligeros para exploradores (simulado)
        for i in range(num_hilos):
            hilo = threading.Thread(target=self._trabajador_explorador, daemon=True)
            hilo.start()
            self.hilos_exploradores.append(hilo)
        self.exploradores_activos = True
        print(colorize(f"✓ Exploradores iniciados con {num_hilos} hilos", "green"))

    def detener_exploradores(self):
        self.exploradores_activos = False
        while not self.cola_ingesta.empty():
            try:
                self.cola_ingesta.get_nowait()
                self.cola_ingesta.task_done()
            except queue.Empty:
                break
        for hilo in self.hilos_exploradores:
            hilo.join(timeout=2)
        self.hilos_exploradores = []
        print(colorize("✓ Exploradores detenidos.", "yellow"))

    def _trabajador_explorador(self):
        while self.exploradores_activos:
            try:
                texto, fuente, etiqueta, categoria = self.cola_ingesta.get(timeout=2)
                self.ingestar_nodo(texto, fuente, etiqueta, categoria, analizar=True)
                self.cola_ingesta.task_done()
            except queue.Empty:
                time.sleep(1)
            except Exception as e:
                print(f"Error en explorador: {e}")

    # ----------------------------------------------------------------------
    # Comandos CLI
    # ----------------------------------------------------------------------
    def cmd_ingesta_masiva(self, archivo):
        if not os.path.exists(archivo):
            print("  Archivo no encontrado.")
            return
        with open(archivo, 'r') as f:
            datos = json.load(f)
        print(f"  Ingiriendo {len(datos)} nodos...")
        for item in datos:
            nombre = item.get("nombre", "")
            periodo = item.get("periodo", "")
            partido = item.get("partido", "")
            logros = item.get("logros", "")
            texto = f"{nombre} – {partido} ({periodo}).\nLogros: {logros}"
            self.ingestar_nodo(texto, "presidentes_usa", "presidente", categoria="historia", analizar=True)
            time.sleep(0.1)
        print("  ✓ Ingesta masiva completada.")

    def run(self):
        print("\n" + "="*70)
        print(" OLLIN – El Ciclo Eterno (v13)")
        print(" AHO como contenedor | Agentes divinos | Enjambre permanente | Trazabilidad espacio‑temporal")
        print(" 'El sistema no piensa, recuerda'")
        print("="*70)
        print(" Comandos: /ingesta_masiva <archivo>, /conocido, /listar, /chat")
        print(" /exploradores on|off, /autonomia on|off, /salir")
        print("="*70)

        while True:
            try:
                entrada = input("\n> ").strip()
                if not entrada:
                    continue
                if entrada == "salir":
                    self.ometeotl.detener()
                    self.coatlicue.detener()
                    self.enjambre.detener()
                    break
                elif entrada.startswith("/ingesta_masiva "):
                    archivo = entrada.split()[1]
                    self.cmd_ingesta_masiva(archivo)
                elif entrada == "/conocido":
                    conn = sqlite3.connect(AHO_DB)
                    c = conn.cursor()
                    c.execute("SELECT id, timestamp_creacion, contenido FROM nodos WHERE tipo='sueno' ORDER BY timestamp_creacion DESC LIMIT 10")
                    for row in c.fetchall():
                        print(f"  {row[0]} [{row[1]}]: {row[2][:80]}")
                    conn.close()
                elif entrada == "/listar":
                    conn = sqlite3.connect(AHO_DB)
                    c = conn.cursor()
                    c.execute("SELECT COUNT(*) FROM nodos")
                    total = c.fetchone()[0]
                    print(f"  Nodos totales en AHO: {total}")
                    conn.close()
                elif entrada.startswith("/chat"):
                    print("Modo conversación (escribe /exit para salir)")
                    while True:
                        msg = input("> ")
                        if msg == "/exit":
                            break
                        if msg:
                            self.ingestar_nodo(msg, "chat_usuario", "conversacion", analizar=False)
                            contexto = self.mecp.exportar(n=10)
                            prompt = f"{contexto}\nUsuario: {msg}\nOLLIN:"
                            respuesta = self.inference.generate(prompt, max_tokens=300)
                            print(f"OLLIN: {respuesta}")
                            self.ingestar_nodo(respuesta, "chat_ollin", "respuesta", analizar=False)
                elif entrada.startswith("/exploradores "):
                    arg = entrada.split()[1]
                    if arg == "on":
                        self.iniciar_exploradores()
                    elif arg == "off":
                        self.detener_exploradores()
                elif entrada.startswith("/autonomia "):
                    arg = entrada.split()[1]
                    if arg == "on":
                        self.ometeotl.iniciar()
                        self.coatlicue.iniciar()
                        self.enjambre.iniciar()
                    elif arg == "off":
                        self.ometeotl.detener()
                        self.coatlicue.detener()
                        self.enjambre.detener()
                else:
                    print("  Comando no reconocido.")
            except KeyboardInterrupt:
                print("\nSaliendo...")
                break
            except Exception as e:
                print(f"  Error: {e}")


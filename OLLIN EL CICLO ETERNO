            },
            "programacion": {
                "keywords": ["programar", "código", "python", "algoritmo"],
                "descripcion": "Desarrollo de software",
                "modelo": "codellama",
                "opuesto": "arte"
            },
            "arte": {
                "keywords": ["arte", "creación", "literatura", "música"],
                "descripcion": "Creación artística",
                "modelo": "llama3",
                "opuesto": "programacion"
            }
        }

    def detectar_tarea(self, texto):
        texto_low = texto.lower()
        if any(k in texto_low for k in ["programar", "código", "python"]):
            return "programacion"
        if any(k in texto_low for k in ["crear", "escribe un poema", "dibuja"]):
            return "arte"
        if any(k in texto_low for k in ["analiza", "evalúa", "crítica"]):
            return "filosofia"
        if any(k in texto_low for k in ["economía", "mercado"]):
            return "economia"
        if any(k in texto_low for k in ["geopolítica", "conflicto"]):
            return "geopolitica"
        return "filosofia"

    def deliberar(self, tema, preguntas_previas=None):
        tarea = self.detectar_tarea(tema)
        grupo = self.grupos.get(tarea, self.grupos["filosofia"])
        modelo = grupo["modelo"]
        prompt = f"""
Eres un grupo de pensamiento especializado en {grupo['descripcion']}.
Sobre el tema: "{tema}"
Genera una voz colectiva: síntesis, preguntas clave y advertencias sobre posibles sesgos.
"""
        respuesta = self.inference.generate(prompt, model=modelo, max_tokens=512)
        return {tarea: respuesta}


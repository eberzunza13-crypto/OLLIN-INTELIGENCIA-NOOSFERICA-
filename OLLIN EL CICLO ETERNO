            nodos = c.fetchall()
            conn.close()
            if nodos:
                nodo_id, texto = nodos[0]  # el más reciente
                # Extraer entidades relacionadas (placeholder)
                # En un caso real usar modelo ligero y encolar nuevos nodos
                registrar_evento("patron_detectado", f"Quetzalcóatl analiza nodo {nodo_id}", nodo_id)

    def detener(self):
        self.activo = False
        if self.hilo_tez:
            self.hilo_tez.join(timeout=2)
        if self.hilo_quez:
            self.hilo_quez.join(timeout=2)


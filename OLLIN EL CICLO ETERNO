            return
        self.activo = True
        self.hilo = threading.Thread(target=self._ciclo, daemon=True)
        self.hilo.start()
        print("✓ Coatlicue sintetizando")

    def _ciclo(self):
        while self.activo:
            time.sleep(30)
            self.procesar_brechas()

    def procesar_brechas(self):
        conn = sqlite3.connect(CONOCIMIENTO_DIOSES)
        c = conn.cursor()
        c.execute("SELECT nodo_id, dimension FROM brechas WHERE resuelta=0")
        brechas = c.fetchall()
        conn.close()
        for nodo_id, dim in brechas:
            # Obtener el nodo original
            conn2 = sqlite3.connect(AHO_DB)
            c2 = conn2.cursor()
            c2.execute("SELECT contenido FROM nodos WHERE id=?", (nodo_id,))
            row = c2.fetchone()
            conn2.close()
            if row:
                texto = row[0]
                # Generar síntesis: tomar el nodo y crear su opuesto simétrico (si no existe) o una integración
                if dim == "simetria":
                    # Crear el Mitote faltante (usando Ollin)
                    mitote_id = self.shell.ollin.desdoblar(nodo_id, texto)
                    # Marcar brecha como resuelta
                    conn3 = sqlite3.connect(CONOCIMIENTO_DIOSES)
                    c3 = conn3.cursor()
                    c3.execute("UPDATE brechas SET resuelta=1 WHERE nodo_id=? AND dimension=?", (nodo_id, dim))
                    conn3.commit()
                    conn3.close()
                    registrar_evento("sintesis_generada", f"Mitote creado para nodo {nodo_id}", mitote_id)

    def detener(self):
        self.activo = False
        if self.hilo:
            self.hilo.join(timeout=2)

class AgenteEnjambre:

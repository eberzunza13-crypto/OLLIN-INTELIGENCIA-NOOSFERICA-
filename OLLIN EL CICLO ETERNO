class AgenteOllin:
    """Agente constitucional: desdobla cada nodo en Sueño/Mitote y verifica principios."""
    def __init__(self, shell):
        self.shell = shell

    def desdoblar(self, nodo_id, texto, categoria=""):
        # Crear nodo Sueño (ya existe) y nodo Mitote (preguntas)
        preguntas = self.generar_preguntas(texto, categoria)
        mitote_id = f"{nodo_id}_mitote"
        guardar_nodo(mitote_id, "mitote", "\n".join(preguntas), "sistema", "pregunta", categoria)
        guardar_relacion(nodo_id, mitote_id, "simetria")
        registrar_evento("simetria_generada", f"Mitote generado desde {nodo_id}", mitote_id)
        return mitote_id

    def generar_preguntas(self, texto, categoria):
        # Usar un modelo ligero para generar preguntas mayéuticas y hermenéuticas
        prompt = f"""
Eres un filósofo socrático y hermeneuta. Genera 5 preguntas profundas sobre el siguiente texto (categoría {categoria}):
{texto[:1000]}
"""
        respuesta = self.shell.inference.generate(prompt, max_tokens=300)
        preguntas = [l.strip() for l in respuesta.split('\n') if l.strip() and '?' in l][:5]
        if not preguntas:
            preguntas = ["¿Qué supuestos subyacen?", "¿Qué perspectivas quedan excluidas?"]
        return preguntas

class AgenteOmeteotl:
    """Observador total. Registra todo y detecta brechas de simetría."""
    def __init__(self, shell):
        self.shell = shell
        self.activo = False
        self.hilo = None

    def iniciar(self):
        if self.activo:
            return
        self.activo = True
        self.hilo = threading.Thread(target=self._ciclo, daemon=True)
        self.hilo.start()
        print("✓ Ometeotl observando")

    def _ciclo(self):
        while self.activo:
            time.sleep(10)  # frecuencia de observación
            self.verificar_simetria()

    def verificar_simetria(self):
        # Buscar nodos Sueño sin su correspondiente Mitote
        conn = sqlite3.connect(AHO_DB)
        c = conn.cursor()
        c.execute("SELECT id FROM nodos WHERE tipo='sueno'")
        suenos = c.fetchall()
        for (sid,) in suenos:
            c.execute("SELECT 1 FROM relaciones WHERE nodo_origen=? AND tipo_relacion='simetria'", (sid,))
            if not c.fetchone():
                registrar_brecha(sid, "simetria", "Falta Mitote simétrico")
                registrar_evento("brecha_detectada", f"Nodo {sid} sin opuesto simétrico", sid)
                # Opcional: notificar al usuario
                print(colorize(f"⚠ Ometeotl: brecha en nodo {sid} (falta simetría)", "yellow"))
        conn.close()

    def detener(self):
        self.activo = False
        if self.hilo:
            self.hilo.join(timeout=2)


class CamaraDialogo:
    def __init__(self, inference_engine):
        self.inference = inference_engine
        self.grupos = self._cargar_grupos()

    def _cargar_grupos(self):
        return {
            "geopolitica": {
                "keywords": ["geopolítica", "conflicto", "guerra", "fronteras", "hegemonía"],
                "descripcion": "Relaciones internacionales",
                "pensadores": ["Noam Chomsky", "John Mearsheimer"]
            },
            "economia": {
                "keywords": ["economía", "mercado", "capitalismo", "deuda", "inflación"],
                "descripcion": "Economía política",
                "pensadores": ["Yanis Varoufakis", "Thomas Piketty"]
            },
            "filosofia": {
                "keywords": ["filosofía", "ética", "existencia", "conocimiento"],
                "descripcion": "Reflexión filosófica",
                "pensadores": ["Sócrates", "Byung-Chul Han"]
            },
            # Se pueden añadir más grupos
        }

    def grupos_relevantes(self, texto):
        texto_low = texto.lower()
        return [nombre for nombre, info in self.grupos.items()
                if any(kw in texto_low for kw in info["keywords"])]

    def deliberar(self, tema, preguntas_previas=None):
        grupos_act = self.grupos_relevantes(tema)
        if not grupos_act:
            grupos_act = ["filosofia"]
        resultados = {}
        for grupo in grupos_act:
            info = self.grupos[grupo]
            prompt = f"""
Eres un grupo de pensamiento que representa la perspectiva **{grupo}** ({info['descripcion']}).
Pensadores clave: {', '.join(info['pensadores'])}.
Sobre el tema: "{tema}"
Preguntas previas: {preguntas_previas if preguntas_previas else 'ninguna'}
Genera una voz colectiva que sintetice el análisis de este grupo.
Incluye: una breve síntesis, 2-3 preguntas clave, y advertencias sobre posibles sesgos.
"""
            # Usar el modelo más potente para la Cámara (configurable)
            respuesta = self.inference.generate(prompt, model="mixtral:8x7b-instruct" if self.inference.backend=="ollama" else "mistral-7b-instruct", max_tokens=512)
            resultados[grupo] = respuesta
        return resultados

# ----------------------------------------------------------------------
# GapHunter unificado (usa todos los motores)
# ----------------------------------------------------------------------
class GapHunter:
    def __init__(self, inference_engine, embedding_engine, vector_db, vision_engine, triaje_engine):
        self.inference = inference_engine
        self.embed = embedding_engine
        self.vectors = vector_db
        self.vision = vision_engine
        self.triaje = triaje_engine
        self.modelos_ligeros = ["phi3", "tinyllama"]  # para exploradores
        self.modelo_principal = "llama3" if inference_engine.backend=="ollama" else "mistral-7b-instruct"
        self.modo_swarm = False

    # ------------------------------------------------------------------
    # Exploradores: usan modelos ligeros para extraer relaciones
    # ------------------------------------------------------------------
    def extraer_relacionados_ligero(self, texto, categoria=""):
        modelo = self.modelos_ligeros[0] if self.modelos_ligeros else self.modelo_principal
        prompt = f"""
Extrae de este texto una lista de personas, lugares, conceptos, eventos u obras relevantes que no sean el tema principal pero estén relacionados.
Devuelve solo una línea por entidad, en formato: "entidad|tipo|categoría_sugerida".
Si no hay, responde "NINGUNO".

Texto: {texto[:1500]}
Categoría original (puede orientar): {categoria}
"""
        respuesta = self.inference.generate(prompt, model=modelo, max_tokens=256)
        if respuesta.strip().upper() == "NINGUNO":
            return []
        entidades = []
        for linea in respuesta.split('\n'):
            if '|' in linea:
                partes = linea.split('|', 2)
                if len(partes) >= 3:
                    entidad, tipo, cat = partes
                    entidades.append((entidad.strip(), tipo.strip(), cat.strip()))
        return entidades

    # ------------------------------------------------------------------
    # Análisis filosófico (puede usar modelo más potente)
    # ------------------------------------------------------------------
    def analizar_con_filosofia(self, texto, categoria=""):
        modelo_analisis = self.modelo_principal
        prompt = f"""
Eres un filósofo socrático y hermeneuta. Genera 5 preguntas profundas sobre el siguiente texto, considerando la categoría {categoria}.
Incluye preguntas que desafíen supuestos y que exploren el contexto histórico y cultural.
Texto: {texto[:1000]}
"""
        respuesta = self.inference.generate(prompt, model=modelo_analisis, max_tokens=300)
        preguntas = [l.strip() for l in respuesta.split('\n') if l.strip() and '?' in l][:5]
        if len(preguntas) < 3:
            preguntas.extend(["¿Qué implicaciones tiene?", "¿Qué perspectivas quedan excluidas?"])
        sugerencias = ["Investigar más sobre este tema", "Consultar fuentes alternativas"]
        return preguntas[:5], sugerencias[:3]

    def procesar_nodo(self, nodo_id, texto, categoria="", corregir_principios=True):
        preguntas, sugerencias = self.analizar_con_filosofia(texto, categoria)
        # Registrar violaciones de principios (simulado)
        return {
            "preguntas": preguntas,
            "sugerencias": sugerencias,
            "analisis": f"Generado con motores multi-capa el {ahora()}"
        }


class OLLINShell:
    def __init__(self):
        # Inicializar motores
        self.inference = InferenceEngine({"backend": "ollama", "model": "phi3"})  # Cambiar a "vllm" si instalas vLLM
        self.embed = EmbeddingEngine()
        self.vectors = VectorDB(self.embed)
        self.vision = VisionEngine()
        self.triaje = TriajeEngine()
        self.gap = GapHunter(self.inference, self.embed, self.vectors, self.vision, self.triaje)
        self.camara = CamaraDialogo(self.inference)
        self.mecp = MECP()
        self.autonomia = CicloAutonomo(self)
        self.modo_swarm = False
        self.cola_ingesta = queue.Queue()
        self.exploradores_activos = False
        self.hilos_exploradores = []

    def encolar_nodo(self, texto, fuente, etiqueta, categoria=""):
        hash_candidato = generar_hash(texto[:100])
        conn = sqlite3.connect(AHO_DB)
        c = conn.cursor()
        c.execute("SELECT id FROM nodos WHERE hash = ?", (hash_candidato,))
        if c.fetchone():
            conn.close()
            return
        conn.close()
        self.cola_ingesta.put((texto, fuente, etiqueta, categoria))

    def iniciar_exploradores(self, num_hilos=2):
        if self.exploradores_activos:
            return
        # Usar modelos ligeros de la lista
        modelos_disponibles = self.inference.modelos_ligeros if hasattr(self.inference, 'modelos_ligeros') else ["phi3"]
        ligeros = [m for m in modelos_disponibles if 'phi' in m or 'tiny' in m or 'gemma' in m]
        if not ligeros:
            ligeros = [self.inference.model_name]
        hilos_a_crear = min(num_hilos, len(ligeros))
        for i in range(hilos_a_crear):
            modelo = ligeros[i % len(ligeros)]
            hilo = threading.Thread(target=self._trabajador_explorador, args=(modelo,), daemon=True)
            hilo.start()
            self.hilos_exploradores.append(hilo)
        self.exploradores_activos = True
        print(colorize(f"✓ Exploradores iniciados con {hilos_a_crear} hilos", "green"))

    def detener_exploradores(self):
        self.exploradores_activos = False
        while not self.cola_ingesta.empty():
            try:
                self.cola_ingesta.get_nowait()
                self.cola_ingesta.task_done()
            except queue.Empty:
                break
        for hilo in self.hilos_exploradores:
            hilo.join(timeout=2)
        self.hilos_exploradores = []
        print(colorize("✓ Exploradores detenidos.", "yellow"))

    def _trabajador_explorador(self, modelo):
        while self.exploradores_activos:
            try:
                texto, fuente, etiqueta, categoria = self.cola_ingesta.get(timeout=2)
                # Ingerir nodo con análisis (usará el GapHunter con su configuración)
                self.ingestar_nodo(texto, fuente, etiqueta, categoria=categoria, analizar=True)
                self.cola_ingesta.task_done()
            except queue.Empty:
                time.sleep(1)
            except Exception as e:
                print(f"Error en explorador: {e}")

    def ingestar_nodo(self, texto, fuente, etiqueta, categoria="", analizar=True):
        if not texto.strip():
            return None
        # Capa AntiBias
        datos = aplicar_antibias(texto, fuente, etiqueta)
        # Triaje (solo etiqueta, no filtra)
        triaje_info = self.triaje.etiquetar(datos["texto_original"])
        # Si el texto es imagen, usar visión
        if etiqueta == "imagen" and os.path.exists(texto):
            desc = self.vision.describe(texto)
            texto = desc
            datos["texto_original"] = desc
        # Guardar nodo
        nodo_existente = buscar_nodo_similar(datos["texto_original"])
        if nodo_existente:
            guardar_adiccion(nodo_existente, datos["texto_original"], fuente, categoria, datos["estado_epistemico"])
            print(colorize(f"  Acumulado en nodo {nodo_existente}", "green"))
            nodo_id = nodo_existente
        else:
            nodo_id = crear_nodo(datos["texto_original"], fuente, etiqueta, categoria, datos["estado_epistemico"])
            if analizar:
                analisis = self.gap.procesar_nodo(nodo_id, datos["texto_original"], categoria)
                # Guardar análisis en mitote
                mitote_path = os.path.join(MITOTE_DIR, f"{nodo_id}.json")
                mitote_data = {
                    "id": nodo_id,
                    "tipo": "mitote",
                    "buscado": {
                        "preguntas": analisis["preguntas"],
                        "sugerencias": analisis["sugerencias"],
                        "analisis": analisis["analisis"],
                        "historial_analisis": []
                    },
                    "triaje": triaje_info  # guardamos metadatos de triaje
                }
                with open(mitote_path, 'w') as f:
                    json.dump(mitote_data, f, ensure_ascii=False, indent=2)
                # Extraer entidades relacionadas usando exploradores (modelo ligero)
                entidades = self.gap.extraer_relacionados_ligero(datos["texto_original"], categoria)
                for ent, tipo, cat in entidades:
                    texto_rel = f"{ent} – {tipo}."
                    self.encolar_nodo(texto_rel, fuente="explorador", etiqueta="relacionado", categoria=cat)
            print(colorize(f"  Nuevo nodo {nodo_id} guardado", "green"))
        self.mecp.registrar("usuario", texto, fuente)

            from transformers import AutoTokenizer, AutoModelForSequenceClassification
            self.bert_tiny = AutoModelForSequenceClassification.from_pretrained("prajjwal1/bert-tiny")
            self.bert_tokenizer = AutoTokenizer.from_pretrained("prajjwal1/bert-tiny")
        except:
            pass

    def etiquetar(self, texto):
        """Devuelve un dict con idioma, relevancia estimada (sin filtrar)"""
        resultado = {
            "idioma_detectado": "desconocido",
            "relevancia_estimada": "media",
            "longitud": len(texto.split())
        }
        # Detección simple de idioma (sin fasttext)
        if any(c in "áéíóúñ" for c in texto.lower()):
            resultado["idioma_detectado"] = "es"
        elif any(c in "абвгдеёжзийклмнопрстуфхцчшщъыьэюя" for c in texto.lower()):
            resultado["idioma_detectado"] = "ru"
        elif any(c in "ءأؤإئآبتثجحخدذرزسشصضطظعغفقكلمنهوي" for c in texto.lower()):
            resultado["idioma_detectado"] = "ar"
        else:
            resultado["idioma_detectado"] = "en"
        # Simulación de relevancia (se puede mejorar)
        resultado["relevancia_estimada"] = "alta" if len(texto.split()) > 10 else "baja"
        return resultado


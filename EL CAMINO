class VisionEngine:
    def __init__(self):
        self.model = None
        self.processor = None
        self.available = False
        try:
            from transformers import AutoModelForCausalLM, AutoTokenizer
            self.model = AutoModelForCausalLM.from_pretrained("vikhyatk/moondream2", trust_remote_code=True)
            self.tokenizer = AutoTokenizer.from_pretrained("vikhyatk/moondream2")
            self.available = True
            print("✓ Moondream2 cargado")
        except Exception as e:
            print(f"⚠ Moondream2 no disponible: {e}. Usando BLIP fallback.")
            try:
                from transformers import BlipProcessor, BlipForConditionalGeneration
                self.processor = BlipProcessor.from_pretrained("Salesforce/blip-image-captioning-base")
                self.model = BlipForConditionalGeneration.from_pretrained("Salesforce/blip-image-captioning-base")
                self.available = True
                print("✓ BLIP cargado (fallback)")
            except Exception as e2:
                print(f"⚠ No se pudo cargar visión: {e2}")

    def describe(self, image_path):
        if not self.available:
            return f"[Imagen] {os.path.basename(image_path)} - descripción no disponible"
        try:
            from PIL import Image
            img = Image.open(image_path).convert('RGB')
            if hasattr(self.model, 'generate_caption'):  # Moondream
                caption = self.model.generate_caption(self.tokenizer, img)
                return caption
            else:  # BLIP
                inputs = self.processor(img, return_tensors="pt")
                out = self.model.generate(**inputs)
                caption = self.processor.decode(out[0], skip_special_tokens=True)
                return caption
        except Exception as e:
            return f"[Error visión] {e}"

